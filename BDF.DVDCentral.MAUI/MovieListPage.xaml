<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="BDF.DVDCentral.MAUI.MovieListPage"
             Title="Movie List" Loaded="ContentPage_Loaded">
    <StackLayout Margin="0" BackgroundColor="CornflowerBlue">
        <CollectionView x:Name="cvMovies" ItemsSource="{Binding movies}">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Grid Padding="10">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Image Grid.RowSpan="2" 
                               Source="{Binding ImagePath}" 
                               Aspect="AspectFill"
                               HeightRequest="60" 
                               WidthRequest="60" />
                        <Label Grid.Column="1" 
                               Text="{Binding Title}" 
                               TextColor="Yellow"
                               FontSize="24"
                               BackgroundColor="#663399"
                               FontAttributes="Bold" />
                        <Label Grid.Row="1"
                               Grid.Column="1" 
                               Text="{Binding FormatDescription}"
                               FontAttributes="Italic" 
                               TextColor="White"
                               FontSize="24"
                               VerticalOptions="End" />
                        <Label Grid.Row="2"
                                Grid.Column="1" 
                                Text="{Binding DirectorFullName}"
                                FontAttributes="Italic" 
                                TextColor="White"
                                FontSize="24"
                                VerticalOptions="End" />
                        <Label Grid.Row="3"
                                Grid.Column="1" 
                                Text="{Binding RatingDescription}"
                                FontAttributes="Italic" 
                                TextColor="White"
                                FontSize="24"
                                VerticalOptions="End" />
                    </Grid>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>
    </StackLayout>
</ContentPage>