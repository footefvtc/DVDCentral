@model FVTC.DVDCentral.BL.Models.Movie

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="m-2">
    <dl class="row">
        <dt class="col-sm-2">
            @Html.DisplayNameFor(model => model.ImagePath)
        </dt>
        <dd class="col-sm-10">
            <img class="imagepropmedium" 
                alt="@Model.Title" 
                onclick="on('/images/@Model.ImagePath')"
                src="~/images/@Model.ImagePath" />
            <span asp-validation-for="ImagePath" class="text-danger"></span>
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Title)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Title)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Description)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Description)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.RatingDescription)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.RatingDescription)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.FormatDescription)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.FormatDescription)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.DirectorFullName)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.DirectorFullName)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.Cost)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.Cost)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.InStkQty)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.InStkQty)
        </dd>
    </dl>
</div>
<div class="m-2">
    <a class="btn btn-primary" asp-route-id="@Model.Id" asp-action="Edit">Edit</a>
    <input class="btn btn-primary"
           type="button"
           onclick="AddToCart(@Model.Id)"
           value="+" />
    <a class="btn btn-primary" asp-action="Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}